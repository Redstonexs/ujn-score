# ==================================================
# 评分系统 - 环境变量配置模板
# ==================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 开发环境可使用默认值，生产环境必须修改标记为 [必须] 的项。

# --------------------------------------------------
# Django 核心配置
# --------------------------------------------------

# [必须] Django SECRET_KEY，生产环境必须设置为随机长字符串
# 可通过以下命令生成：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-random-secret-key-here

# [必须] 关闭 Debug 模式（生产环境务必设为 False）
DJANGO_DEBUG=False

# [必须] 允许访问的主机名，逗号分隔
# 示例：DJANGO_ALLOWED_HOSTS=score.example.com,www.score.example.com
DJANGO_ALLOWED_HOSTS=score.example.com

# --------------------------------------------------
# CORS 跨域配置
# --------------------------------------------------

# [推荐] 前端域名，逗号分隔。留空则允许所有来源（不推荐用于生产环境）
# 示例：CORS_ALLOWED_ORIGINS=https://score.example.com,https://www.score.example.com
CORS_ALLOWED_ORIGINS=https://score.example.com

# --------------------------------------------------
# MySQL 数据库配置
# --------------------------------------------------

# 使用 MySQL 时设为 1；留空或 0 时使用 ujn/db.sqlite3
USE_MYSQL=1

# [必须] 数据库密码（生产环境强制要求设置）
MYSQL_PASSWORD=your-db-password-here

# 数据库名（默认：ujn）
MYSQL_DATABASE=ujn

# 数据库用户名（默认：ujn）
MYSQL_USER=ujn

# 数据库主机（默认：127.0.0.1）
MYSQL_HOST=127.0.0.1

# 数据库端口（默认：3307）
MYSQL_PORT=3307

# --------------------------------------------------
# 安全相关
# --------------------------------------------------

# 清空操作密码（用于清空评分/选手/评委/类别数据）
CLEAR_PASSWORD=jndx

# --------------------------------------------------
# uWSGI 部署（仅使用 uwsgi.ini 时需要）
# --------------------------------------------------

# Python 虚拟环境路径
# UWSGI_VENV=/root/miniconda3/envs/web
