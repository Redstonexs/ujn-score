# Django 安全密钥，生产环境请务必修改
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式 (1, true, yes 表示开启)，生产环境必须设为 False
DJANGO_DEBUG=True

# 允许的域名或IP（逗号分隔），生产环境需配置，例如 example.com,127.0.0.1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 允许跨域请求的来源（逗号分隔），例如 https://score.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL 数据库配置
USE_MYSQL=1
MYSQL_DATABASE=ujn
MYSQL_USER=ujn
MYSQL_PASSWORD=ujn2026
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307

# 清空数据时使用的特殊密码，生产环境务必修改
CLEAR_PASSWORD=jndx
